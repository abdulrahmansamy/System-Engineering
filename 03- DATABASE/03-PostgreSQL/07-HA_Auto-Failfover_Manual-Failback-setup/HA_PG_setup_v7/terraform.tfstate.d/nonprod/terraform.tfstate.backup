        "metadata_fingerprint": "n97RK488V-c=",
        "metadata_startup_script": "#!/bin/bash\n# PostgreSQL High Availability Cluster Bootstrap Script\n# Production-ready startup script for GCP Compute Engine\n# Supports: Ubuntu 24.04 LTS, PostgreSQL 17, repmgr HA with automatic failover\n# Version: 1.0.1 (Consolidated)\n\nset -euo pipefail\n\n# ============================================================================\n# CONFIGURATION \u0026 GLOBAL VARIABLES\n# ============================================================================\n\nSCRIPT_VERSION=\"1.2.0\"\nBOOTSTRAP_START_TIME=$(date +%s)\n\n# Enable detailed tracing for debugging\nif [[ \"${BOOTSTRAP_TRACE:-0}\" == \"1\" ]]; then\n  export PS4='\\nTRACE [$LINENO] \u003e\u003e '\n  set -x\nfi\n\n# Directories and paths\nLOG_DIR=\"/var/log/pg-bootstrap\"\nLOG_FILE=\"$LOG_DIR/bootstrap.log\"\nSENTINEL_DIR=\"/var/lib/postgresql/.bootstrap\"\nSENTINEL_BOOTSTRAP=\"${SENTINEL_DIR}/done\"\nSENTINEL_PRIMARY_INIT=\"${SENTINEL_DIR}/primary.init\"\nSENTINEL_STANDBY_CLONED=\"${SENTINEL_DIR}/standby.cloned\"\n\n# PostgreSQL configuration\nPG_VERSION=\"17\"\nPG_CLUSTER_NAME=\"main\"\nPG_DATA_DIR=\"/var/lib/postgresql/${PG_VERSION}/${PG_CLUSTER_NAME}\"\nREPMGR_CONF_DIR=\"/etc/repmgr\"\nREPMGR_CONF_FILE=\"${REPMGR_CONF_DIR}/repmgr.conf\"\nREPMGR_LOG_DIR=\"/var/log/repmgr\"\nREPMGR_EVENTS_DIR=\"/etc/repmgr/events\"\nHEALTH_BIN=\"/usr/local/bin/pg-ha-health.sh\"\nHEALTH_SERVICE=\"pg-ha-health.service\"\n\n# PgBouncer configuration\nPGBOUNCER_CONF_DIR=\"/etc/pgbouncer\"\nPGBOUNCER_CONF_FILE=\"${PGBOUNCER_CONF_DIR}/pgbouncer.ini\"\nPGBOUNCER_USERLIST_FILE=\"${PGBOUNCER_CONF_DIR}/userlist.txt\"\nPGBOUNCER_PORT=6432\nPGBOUNCER_POOL_SIZE=25\nPGBOUNCER_MAX_CLIENT_CONN=100\nPGBOUNCER_HEALTH_BIN=\"/usr/local/bin/pgbouncer-health.sh\"\nPGBOUNCER_HEALTH_SERVICE=\"pgbouncer-health.service\"\n\n# Create required directories\nmkdir -p \"$LOG_DIR\" \"$SENTINEL_DIR\" \"$REPMGR_CONF_DIR\" \"$REPMGR_LOG_DIR\" \"$REPMGR_EVENTS_DIR\"\ntouch \"$LOG_FILE\"\nchmod 644 \"$LOG_FILE\" || true\n\n# ============================================================================\n# LOGGING FUNCTIONS\n# ============================================================================\n\nts() { date -u +%Y-%m-%dT%H:%M:%SZ; }\n\nlog() {\n  local lvl msg\n  case \"$1\" in\n    INFO|WARN|ERROR|DEBUG) lvl=\"$1\"; shift; msg=\"$*\" ;;\n    *) lvl=INFO; msg=\"$*\" ;;\n  esac\n  local line=\"$(ts) [$lvl] $msg\"\n  echo \"$line\" \u003e\u003e \"$LOG_FILE\"\n  if command -v systemd-cat \u003e/dev/null 2\u003e\u00261; then\n    echo \"$line\" | systemd-cat -t pg-bootstrap || true\n  fi\n  if [[ -t 1 ]]; then\n    local color='\\033[0m'\n    case \"$lvl\" in\n      INFO) color='\\033[0;32m';; WARN) color='\\033[0;33m';;\n      ERROR) color='\\033[0;31m';; DEBUG) color='\\033[0;34m';;\n    esac\n    printf \"%b%s\\033[0m\\n\" \"$color\" \"$line\"\n  fi\n}\n\ninfo() { log INFO \"$*\"; }\nwarn() { log WARN \"$*\"; }\nerror() { log ERROR \"$*\"; }\ndebug() { [[ \"${BOOTSTRAP_DEBUG:-false}\" =~ ^(true|1)$ ]] \u0026\u0026 log DEBUG \"$*\" || true; }\ndie() { log ERROR \"$*\"; exit 1; }\n\nretry() {\n  local -i n=$1; shift; local -i delay=$1; shift; local i=0\n  until \"$@\"; do\n    i=$((i+1))\n    if (( i \u003e= n )); then return 1; fi\n    sleep \"$delay\"\n  done\n}\n\n# Error handling\ntrap 'rc=$?; if (( rc != 0 )); then log ERROR \"Bootstrap script exiting with code $rc (last cmd: $BASH_COMMAND line $LINENO)\"; fi' EXIT\ntrap 'log ERROR \"Error trapped at line $LINENO during: $BASH_COMMAND\"' ERR\n\n# ============================================================================\n# METADATA AND CONFIGURATION DETECTION\n# ============================================================================\n\nget_metadata() {\n  local key=\"$1\" default=\"$2\"\n  curl -sf -H 'Metadata-Flavor: Google' \\\n    \"http://metadata.google.internal/computeMetadata/v1/instance/attributes/$key\" 2\u003e/dev/null || echo \"$default\"\n}\n\ndetect_configuration() {\n  info \"Detecting cluster configuration from GCP metadata\"\n  \n  # Core configuration\n  export PROJECT_ID=\"${PROJECT_ID:-$(curl -sf -H 'Metadata-Flavor: Google' http://metadata.google.internal/computeMetadata/v1/project/project-id || echo unknown)}\"\n  export ROLE=\"${ROLE:-$(get_metadata pg_role unknown)}\"\n  export CLUSTER_ID=\"${CLUSTER_ID:-$(get_metadata pg_cluster_id ha-cluster)}\"\n  export REPMGR_PRIMARY_HOST=\"${REPMGR_PRIMARY_HOST:-$(get_metadata repmgr_primary_host pg-primary)}\"\n  export REPMGR_DB=\"${REPMGR_DB:-$(get_metadata repmgr_db repmgr)}\"\n  export REPMGR_USER=\"${REPMGR_USER:-$(get_metadata repmgr_user repmgr)}\"\n  export HEALTH_PORT=\"${HEALTH_PORT:-$(get_metadata pg_health_port 8001)}\"\n  \n  # Get local IP\n  local self_ip\n  self_ip=$(hostname -I 2\u003e/dev/null | awk '{for(i=1;i\u003c=NF;i++) if($i !~ /^127\\./){print $i; exit}}' || true)\n  export SELF_IP=\"$self_ip\"\n  \n  # Auto-detect role if not set\n  if [[ \"$ROLE\" == \"unknown\" ]]; then\n    if [[ -f \"${PG_DATA_DIR}/PG_VERSION\" ]]; then\n      if sudo -u postgres psql -Atqc \"select pg_is_in_recovery()\" postgres 2\u003e/dev/null | grep -q '^t'; then\n        ROLE=\"standby\"\n      else\n        ROLE=\"primary\"\n      fi\n    else\n      if [[ -n \"$REPMGR_PRIMARY_HOST\" \u0026\u0026 \"$REPMGR_PRIMARY_HOST\" != \"pg-primary\" ]]; then\n        if timeout 2 bash -c \"\u003c/dev/tcp/${REPMGR_PRIMARY_HOST}/5432\" 2\u003e/dev/null; then\n          ROLE=\"standby\"\n        else\n          ROLE=\"primary\"\n        fi\n      else\n        ROLE=\"primary\"\n      fi\n    fi\n    info \"Auto-detected ROLE=$ROLE\"\n  fi\n  \n  # Set primary host to self IP if this is the primary\n  if [[ \"$ROLE\" == \"primary\" \u0026\u0026 ( -z \"$REPMGR_PRIMARY_HOST\" || \"$REPMGR_PRIMARY_HOST\" == \"pg-primary\" ) ]]; then\n    REPMGR_PRIMARY_HOST=\"$self_ip\"\n    info \"Set REPMGR_PRIMARY_HOST=$REPMGR_PRIMARY_HOST\"\n  fi\n  \n  info \"Configuration: role=$ROLE cluster=$CLUSTER_ID project=$PROJECT_ID primary_host=$REPMGR_PRIMARY_HOST self_ip=$self_ip\"\n}\n\n# ============================================================================\n# SECRET MANAGEMENT\n# ============================================================================\n\n# Auto-fix password loading for standby nodes\nauto_fix_repmgr_password() {\n  # Only run for standby nodes and if REPMGR_PASSWORD is not already set\n  if [[ \"$ROLE\" != \"standby\" || -n \"${REPMGR_PASSWORD:-}\" ]]; then\n    debug \"Skipping auto-fix: ROLE=$ROLE, REPMGR_PASSWORD already set: $([[ -n \"${REPMGR_PASSWORD:-}\" ]] \u0026\u0026 echo \"yes\" || echo \"no\")\"\n    return 0\n  fi\n  \n  info \"🔧 Auto-fixing repmgr password for standby node\"\n  \n  local env_code=\"$(get_metadata env_code unknown)\"\n  local org_code=\"$(get_metadata org_code unknown)\"\n  local repmgr_secret=\"${org_code}-${env_code}-sec-repmgr-password-01\"\n  info \"  → Using repmgr Secret Manager ID: $repmgr_secret\"\n  info \"  → Project ID: $PROJECT_ID\"\n  \n  # Try direct Secret Manager access (simplified approach)\n  local token password\n  info \"  → Getting access token for auto-fix...\"\n  token=$(curl -sf -H 'Metadata-Flavor: Google' \\\n    'http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token' | \\\n    jq -r '.access_token' 2\u003e/dev/null || true)\n  \n  if [[ -n \"$token\" ]]; then\n    info \"  ✓ Access token obtained for auto-fix\"\n    local url=\"https://secretmanager.googleapis.com/v1/projects/${PROJECT_ID}/secrets/${repmgr_secret}/versions/latest:access\"\n    info \"  → Calling Secret Manager API: $url\"\n    \n    local body\n    if body=$(curl -sf -H \"Authorization: Bearer $token\" -H 'Accept: application/json' \"$url\" 2\u003e/dev/null); then\n      info \"  ✓ Secret Manager API call successful\"\n      if password=$(echo \"$body\" | jq -r '.payload.data' | base64 -d 2\u003e/dev/null); then\n        export REPMGR_PASSWORD=\"$password\"\n        info \"  ✓ Auto-fixed repmgr password from Secret Manager (length: ${#REPMGR_PASSWORD} characters)\"\n        return 0\n      else\n        warn \"  ✗ Failed to decode auto-fix secret payload\"\n      fi\n    else\n      warn \"  ✗ Secret Manager API call failed for auto-fix\"\n    fi\n  else\n    warn \"  ✗ Failed to get access token for auto-fix\"\n  fi\n  \n  warn \"⚠ Auto-fix failed, will use fallback password generation\"\n  return 1\n}\n\n# Token cache for Secret Manager access\nTOKEN_CACHE=\"/run/pg-secrets/token.json\"\nSECRET_CACHE_DIR=\"/run/pg-secrets\"\n\n_fetch_token() {\n  local now exp\n  if [[ -f $TOKEN_CACHE ]]; then\n    exp=$(jq -r '.expiration // 0' \"$TOKEN_CACHE\" 2\u003e/dev/null || echo 0)\n    [[ $exp =~ ^[0-9]+$ ]] || exp=0\n    now=$(date +%s)\n    if (( now+60 \u003c exp )); then return 0; fi\n  fi\n  local raw\n  raw=$(curl -sf -H 'Metadata-Flavor: Google' \\\n       'http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token') || return 1\n  echo \"$raw\" \u003e \"$TOKEN_CACHE\"\n}\n\nget_secret() {\n  local name=\"$1\" sid=\"$2\" cache=\"$SECRET_CACHE_DIR/$name\"\n  if [[ -s $cache ]]; then cat \"$cache\"; return 0; fi\n  \n  # Simplified approach - get token directly\n  local token\n  token=$(curl -sf -H 'Metadata-Flavor: Google' \\\n    'http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token' | \\\n    jq -r '.access_token' 2\u003e/dev/null || true)\n  \n  if [[ -z \"$token\" ]]; then \n    warn \"Failed to get access token for $sid\"\n    return 1\n  fi\n  \n  local url=\"https://secretmanager.googleapis.com/v1/projects/${PROJECT_ID}/secrets/${sid}/versions/latest:access\"\n  local body\n  if ! body=$(curl -sf -H \"Authorization: Bearer $token\" -H 'Accept: application/json' \"$url\" 2\u003e/dev/null); then\n    warn \"Failed to retrieve secret $sid\"\n    return 1\n  fi\n  \n  local secret_value\n  if ! secret_value=$(echo \"$body\" | jq -r '.payload.data' | base64 -d 2\u003e/dev/null); then\n    warn \"Failed to decode secret $sid\"\n    return 1\n  fi\n  \n  # Cache the secret\n  echo \"$secret_value\" \u003e \"$cache\" 2\u003e/dev/null || true\n  chmod 600 \"$cache\" 2\u003e/dev/null || true\n  \n  echo \"$secret_value\"\n}\n\nload_secrets() {\n  info \"Loading secrets from Secret Manager\"\n  mkdir -p \"$SECRET_CACHE_DIR\"\n  \n  # Initialize variables with defaults\n  export PGBOUNCER_PASSWORD=\"${PGBOUNCER_PASSWORD:-}\"\n  \n  # Generate secure passwords as fallback\n  gen_pw() {\n    if command -v openssl \u003e/dev/null 2\u003e\u00261; then\n      openssl rand -base64 24 2\u003e/dev/null | tr -d '=+/' | cut -c1-32\n    else\n      cat /dev/urandom | tr -dc 'A-Za-z0-9' | head -c32\n    fi\n  }\n  \n  # Enhanced Secret Manager helper function with detailed logging\n  get_secret_enhanced() {\n    local secret_id=\"$1\"\n    info \"🔐 Attempting to retrieve secret: $secret_id\"\n    \n    # Get access token\n    local token\n    info \"  → Getting GCP access token...\"\n    token=$(curl -sf -H 'Metadata-Flavor: Google' \\\n      'http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token' | \\\n      jq -r '.access_token' 2\u003e/dev/null || true)\n    \n    if [[ -z \"$token\" ]]; then \n      warn \"  ✗ Failed to get access token for $secret_id\"\n      return 1\n    fi\n    info \"  ✓ Access token obtained\"\n    \n    # Construct URL and make request\n    local url=\"https://secretmanager.googleapis.com/v1/projects/${PROJECT_ID}/secrets/${secret_id}/versions/latest:access\"\n    info \"  → Calling Secret Manager API: $url\"\n    \n    local body\n    if body=$(curl -sf -H \"Authorization: Bearer $token\" -H 'Accept: application/json' \"$url\" 2\u003e/dev/null); then\n      info \"  ✓ Secret Manager API call successful\"\n      local secret_value\n      if secret_value=$(echo \"$body\" | jq -r '.payload.data' | base64 -d 2\u003e/dev/null); then\n        info \"  ✓ Secret decoded successfully (length: ${#secret_value} characters)\"\n        echo \"$secret_value\"\n        return 0\n      else\n        warn \"  ✗ Failed to decode secret payload\"\n        return 1\n      fi\n    else\n      warn \"  ✗ Secret Manager API call failed for $secret_id\"\n      return 1\n    fi\n  }\n  \n  # Get environment and org codes from metadata (set by Terraform)\n  local env_code=\"$(get_metadata env_code unknown)\"\n  local org_code=\"$(get_metadata org_code unknown)\"\n  \n  # Secret IDs matching your Terraform configuration\n  local pg_superuser_secret=\"${org_code}-${env_code}-sec-pg-superuser-password-01\"\n  local pg_repl_secret=\"${org_code}-${env_code}-sec-pg-replication-password-01\" \n  local pg_monitor_secret=\"${org_code}-${env_code}-sec-pg-monitor-password-01\"\n  local repmgr_secret=\"${org_code}-${env_code}-sec-repmgr-password-01\"\n  local pgbouncer_secret=\"${org_code}-${env_code}-sec-pgbouncer-password-01\"\n \n  \n  # Load repmgr password first - prefer environment variable if set, then enhanced Secret Manager\n  if [[ -n \"${REPMGR_PASSWORD:-}\" ]]; then\n    info \"✓ Using pre-set repmgr password from environment (length: ${#REPMGR_PASSWORD} characters)\"\n  else\n    # Try enhanced Secret Manager approach first\n    set +e\n    export REPMGR_PASSWORD=\"$(get_secret_enhanced \"$repmgr_secret\" 2\u003e/dev/null || get_secret repmgr \"$repmgr_secret\" 2\u003e/dev/null || get_metadata repmgr_password \"$(gen_pw)\")\"\n    set -e\n    \n    # Validate we got a proper password\n    if [[ -n \"$REPMGR_PASSWORD\" \u0026\u0026 \"${#REPMGR_PASSWORD}\" -gt 10 ]]; then\n      info \"✓ Successfully loaded repmgr password from Secret Manager (length: ${#REPMGR_PASSWORD} characters)\"\n    else\n      warn \"⚠ Repmgr password load failed, generating secure fallback\"\n      export REPMGR_PASSWORD=\"$(gen_pw)\"\n    fi\n  fi\n  \n  # Load other secrets with fallbacks and detailed logging\n  set +e\n  \n  # PostgreSQL Superuser Password\n  info \"🔐 Loading PostgreSQL superuser password...\"\n  if [[ -n \"${PG_SUPER_PASS:-}\" ]]; then\n    info \"  ✓ Using pre-set superuser password from environment\"\n  else\n    if PG_SUPER_PASS=$(get_secret_enhanced \"$pg_superuser_secret\"); then\n      info \"  ✓ Retrieved superuser password from Secret Manager\"\n      export PG_SUPER_PASS\n    else\n      warn \"  ⚠ Failed to retrieve from Secret Manager, trying legacy method...\"\n      if PG_SUPER_PASS=$(get_secret pg_superuser \"$pg_superuser_secret\" 2\u003e/dev/null); then\n        info \"  ✓ Retrieved superuser password via legacy method\"\n        export PG_SUPER_PASS\n      else\n        warn \"  ✗ All retrieval methods failed, generating fallback password\"\n        export PG_SUPER_PASS=\"$(gen_pw)\"\n      fi\n    fi\n  fi\n  \n  # PostgreSQL Replication Password\n  info \"🔐 Loading PostgreSQL replication password...\"\n  if [[ -n \"${PG_REPL_PASS:-}\" ]]; then\n    info \"  ✓ Using pre-set replication password from environment\"\n  else\n    if PG_REPL_PASS=$(get_secret_enhanced \"$pg_repl_secret\"); then\n      info \"  ✓ Retrieved replication password from Secret Manager\"\n      export PG_REPL_PASS\n    else\n      warn \"  ⚠ Failed to retrieve from Secret Manager, trying legacy method...\"\n      if PG_REPL_PASS=$(get_secret pg_repl \"$pg_repl_secret\" 2\u003e/dev/null); then\n        info \"  ✓ Retrieved replication password via legacy method\"\n        export PG_REPL_PASS\n      else\n        warn \"  ✗ All retrieval methods failed, generating fallback password\"\n        export PG_REPL_PASS=\"$(gen_pw)\"\n      fi\n    fi\n  fi\n  \n  # PostgreSQL Monitor Password\n  info \"🔐 Loading PostgreSQL monitor password...\"\n  if [[ -n \"${PG_MONITOR_PASS:-}\" ]]; then\n    info \"  ✓ Using pre-set monitor password from environment\"\n  else\n    if PG_MONITOR_PASS=$(get_secret_enhanced \"$pg_monitor_secret\"); then\n      info \"  ✓ Retrieved monitor password from Secret Manager\"\n      export PG_MONITOR_PASS\n    else\n      warn \"  ⚠ Failed to retrieve from Secret Manager, trying legacy method...\"\n      if PG_MONITOR_PASS=$(get_secret pg_monitor \"$pg_monitor_secret\" 2\u003e/dev/null); then\n        info \"  ✓ Retrieved monitor password via legacy method\"\n        export PG_MONITOR_PASS\n      else\n        warn \"  ✗ All retrieval methods failed, generating fallback password\"\n        export PG_MONITOR_PASS=\"$(gen_pw)\"\n      fi\n    fi\n  fi\n  \n  # PgBouncer Password\n  # PgBouncer Password\n  info \"🔐 Loading PgBouncer password...\"\n  info \"  → Secret ID: $pgbouncer_secret\"\n  if [[ -n \"${PGBOUNCER_PASSWORD:-}\" ]]; then\n    info \"  ✓ Using pre-set PgBouncer password from environment\"\n  else\n    if PGBOUNCER_PASSWORD=$(get_secret_enhanced \"$pgbouncer_secret\"); then\n      info \"  ✓ Retrieved PgBouncer password from Secret Manager\"\n      export PGBOUNCER_PASSWORD\n    else\n      warn \"  ⚠ Failed to retrieve from Secret Manager, trying legacy method...\"\n      if PGBOUNCER_PASSWORD=$(get_secret pgbouncer \"$pgbouncer_secret\" 2\u003e/dev/null); then\n        info \"  ✓ Retrieved PgBouncer password via legacy method\"\n        export PGBOUNCER_PASSWORD\n      else\n        warn \"  ✗ All retrieval methods failed, generating fallback password\"\n        export PGBOUNCER_PASSWORD=\"$(gen_pw)\"\n      fi\n    fi\n  fi\n  \n  # Validate all passwords are properly loaded (enhanced validation)\n  local password_validation_failed=0\n  \n  if [[ -z \"$PG_SUPER_PASS\" || \"$PG_SUPER_PASS\" == \"changeMe\" || \"${#PG_SUPER_PASS}\" -lt 8 ]]; then\n    warn \"PostgreSQL superuser password validation failed, generating secure fallback\"\n    PG_SUPER_PASS=\"$(gen_pw)\"\n    password_validation_failed=1\n    info \"  → New superuser generated password length: ${#PG_SUPER_PASS} characters\"\n  fi\n  \n  if [[ -z \"$PG_REPL_PASS\" || \"$PG_REPL_PASS\" == \"changeMe\" || \"${#PG_REPL_PASS}\" -lt 8 ]]; then\n    warn \"PostgreSQL replication password validation failed, generating secure fallback\"\n    PG_REPL_PASS=\"$(gen_pw)\"\n    password_validation_failed=1\n    info \"  → New replication generated password length: ${#PG_REPL_PASS} characters\"\n  fi\n  \n  if [[ -z \"$PG_MONITOR_PASS\" || \"$PG_MONITOR_PASS\" == \"changeMe\" || \"${#PG_MONITOR_PASS}\" -lt 8 ]]; then\n    warn \"PostgreSQL monitor password validation failed, generating secure fallback\"\n    PG_MONITOR_PASS=\"$(gen_pw)\"\n    password_validation_failed=1\n    info \"  → New monitor generated password length: ${#PG_MONITOR_PASS} characters\"\n  fi\n  \n  if [[ -z \"$PGBOUNCER_PASSWORD\" || \"$PGBOUNCER_PASSWORD\" == \"changeMe\" || \"${#PGBOUNCER_PASSWORD}\" -lt 8 ]]; then\n    warn \"PgBouncer admin password validation failed, generating secure fallback\"\n    PGBOUNCER_PASSWORD=\"$(gen_pw)\"\n    password_validation_failed=1\n    info \"  → New PgBouncer generated password length: ${#PGBOUNCER_PASSWORD} characters\"\n  fi\n  \n  if [[ -z \"$REPMGR_PASSWORD\" || \"$REPMGR_PASSWORD\" == \"changeMe\" || \"${#REPMGR_PASSWORD}\" -lt 8 ]]; then\n    warn \"Repmgr password validation failed, generating secure fallback\"\n    REPMGR_PASSWORD=\"$(gen_pw)\"\n    password_validation_failed=1\n    info \"  → New repmgr generated password length: ${#REPMGR_PASSWORD} characters\"\n  fi\n  \n  # Log validation results\n  if [[ $password_validation_failed -eq 1 ]]; then\n    warn \"⚠️  Some passwords were generated as fallbacks due to Secret Manager issues\"\n    warn \"   Consider updating Secret Manager with proper passwords after deployment\"\n  else\n    info \"✅ All passwords successfully loaded from Secret Manager\"\n  fi\n  \n  set -e\n  export PGPASSWORD=\"$PG_SUPER_PASS\"\n  \n  # Log final password loading summary\n  info \"📋 Password Loading Summary:\"\n  info \"  → PostgreSQL Superuser: ${#PG_SUPER_PASS} characters ✓\"\n  info \"  → PostgreSQL Replication: ${#PG_REPL_PASS} characters ✓\"\n  info \"  → PostgreSQL Monitor: ${#PG_MONITOR_PASS} characters ✓\"\n  info \"  → PgBouncer: ${#PGBOUNCER_PASSWORD} characters ✓\"\n  info \"  → Repmgr: ${#REPMGR_PASSWORD} characters ✓\"\n  info \"✅ All secrets loaded successfully with fallbacks where needed\"\n  \n}\n\n# ============================================================================\n# PGBOUNCER CONFIGURATION AND SETUP\n# ============================================================================\n\ninstall_pgbouncer() {\n  info \"Installing and configuring PgBouncer\"\n  \n  # Install PgBouncer if not already installed\n  if ! command -v pgbouncer \u003e/dev/null 2\u003e\u00261; then\n    info \"Installing PgBouncer package\"\n    apt-get update \u0026\u0026 apt-get install -y pgbouncer socat || die \"Failed to install PgBouncer\"\n  else\n    info \"✓ PgBouncer already installed\"\n  fi\n  \n  # Create pgbouncer user if it doesn't exist\n  if ! id -u pgbouncer \u003e/dev/null 2\u003e\u00261; then\n    useradd --system --home-dir /var/lib/pgbouncer --shell /bin/false pgbouncer\n    info \"✓ Created pgbouncer system user\"\n  else\n    info \"✓ pgbouncer user already exists\"\n  fi\n  \n  # Create directories\n  mkdir -p /var/lib/pgbouncer /var/log/pgbouncer \"$PGBOUNCER_CONF_DIR\" /var/run/pgbouncer\n  \n  # Set proper ownership\n  chown -R pgbouncer:pgbouncer \"$PGBOUNCER_CONF_DIR\" /var/lib/pgbouncer /var/log/pgbouncer /var/run/pgbouncer\n  chmod 750 \"$PGBOUNCER_CONF_DIR\" /var/lib/pgbouncer\n}\n\nconfigure_pgbouncer() {\n  info \"Configuring PgBouncer for role: $ROLE with SCRAM-SHA-256 authentication\"\n  \n  # Determine PgBouncer mode based on role\n  local pool_mode max_client_conn\n  case \"$ROLE\" in\n    primary)\n      pool_mode=\"session\"      # Session mode for writes\n      max_client_conn=100\n      ;;\n    standby)\n      pool_mode=\"transaction\"  # Transaction mode for reads\n      max_client_conn=150\n      ;;\n    *)\n      pool_mode=\"session\"\n      max_client_conn=50\n      ;;\n  esac\n  \n  info \"PgBouncer mode: $pool_mode, max_client_conn: $max_client_conn\"\n  \n  # Create PgBouncer configuration with SCRAM-SHA-256 support\n  cat \u003e \"$PGBOUNCER_CONF_FILE\" \u003c\u003cEOF\n;; PgBouncer HA configuration with SCRAM-SHA-256 authentication\n;; Generated by bootstrap script - Role: $ROLE\n\n[databases]\npostgres = host=localhost port=5432 dbname=postgres\ntemplate1 = host=localhost port=5432 dbname=template1\n${REPMGR_DB} = host=localhost port=5432 dbname=${REPMGR_DB}\n\n;; NOTE: pgbouncer is a reserved database name and should NOT be listed here\n;; Admin connections to pgbouncer use the special \"pgbouncer\" database automatically\n\n[pgbouncer]\n;; Connection settings\nlisten_addr = 0.0.0.0\nlisten_port = $PGBOUNCER_PORT\n\n;; SCRAM-SHA-256 Authentication (Enhanced Security)\nauth_type = scram-sha-256\nauth_file = $PGBOUNCER_USERLIST_FILE\nauth_query = SELECT usename, passwd FROM pg_shadow WHERE usename = \\$1\nauth_user = postgres\n\n;; Pool settings\npool_mode = $pool_mode\nmax_client_conn = $max_client_conn\ndefault_pool_size = $PGBOUNCER_POOL_SIZE\nreserve_pool_size = 5\nmax_db_connections = $((PGBOUNCER_POOL_SIZE * 2))\n\n;; Timeouts\nserver_connect_timeout = 15\nserver_login_retry = 3\nquery_timeout = 3600\nquery_wait_timeout = 120\nclient_idle_timeout = 3600\nserver_idle_timeout = 600\nserver_lifetime = 3600\n\n;; Logging\nlog_connections = 1\nlog_disconnections = 1\nlog_pooler_errors = 1\nsyslog = 0\nsyslog_facility = daemon\nlog_stats = 1\nstats_period = 60\n\n;; Administration (Enhanced Security Model)\nadmin_users = pgbouncer_admin\nstats_users = pgbouncer_admin\n\n;; Security\nignore_startup_parameters = extra_float_digits,search_path\n\n;; Connection limits per user/database\nmax_user_connections = $((max_client_conn / 2))\n\n;; Server settings\nserver_reset_query = DISCARD ALL\nserver_reset_query_always = 0\nserver_check_delay = 30\n\n;; Performance\ntcp_keepalive = 1\ntcp_keepcnt = 3\ntcp_keepidle = 600\ntcp_keepintvl = 30\n\n;; Application name tracking\napplication_name_add_host = 1\nEOF\n\n  chown pgbouncer:pgbouncer \"$PGBOUNCER_CONF_FILE\"\n  chmod 640 \"$PGBOUNCER_CONF_FILE\"\n  info \"✓ PgBouncer configuration created for $ROLE mode with SCRAM-SHA-256\"\n}\n\ncreate_pgbouncer_userlist() {\n  info \"Creating PgBouncer SCRAM-SHA-256 authentication file\"\n  \n  # For SCRAM-SHA-256 with auth_query, we need minimal userlist\n  # Real authentication happens via auth_query to PostgreSQL\n  cat \u003e \"$PGBOUNCER_USERLIST_FILE\" \u003c\u003cEOF\n;; PgBouncer SCRAM-SHA-256 Authentication File\n;; Generated by bootstrap script\n;; Using auth_query mode - passwords verified directly from PostgreSQL\n\n;; Auth user entry (required for auth_query functionality)\n;; Empty password - authentication handled by auth_query\n\"postgres\" \"\"\n\n;; Admin user placeholder (authentication via PostgreSQL)\n\"pgbouncer_admin\" \"\"\n\nEOF\n\n  chown pgbouncer:pgbouncer \"$PGBOUNCER_USERLIST_FILE\"\n  chmod 640 \"$PGBOUNCER_USERLIST_FILE\"\n  info \"✓ SCRAM-SHA-256 authentication file created with auth_query mode\"\n}\n\nsetup_pgbouncer_service() {\n  info \"Setting up PgBouncer systemd service\"\n  \n  # Create systemd service file\n  cat \u003e /etc/systemd/system/pgbouncer.service \u003c\u003cEOF\n[Unit]\nDescription=PgBouncer connection pooler for PostgreSQL\nDocumentation=man:pgbouncer(1)\nAfter=network.target postgresql.service\nWants=postgresql.service\n\n[Service]\nType=notify\nExecStart=/usr/sbin/pgbouncer $PGBOUNCER_CONF_FILE\nExecReload=/bin/kill -HUP \\$MAINPID\nKillSignal=SIGINT\nUser=pgbouncer\nGroup=pgbouncer\nPIDFile=/var/run/pgbouncer/pgbouncer.pid\nRuntimeDirectory=pgbouncer\nRuntimeDirectoryMode=0755\n\n# Security settings\nNoNewPrivileges=true\nPrivateTmp=true\nPrivateDevices=true\nProtectSystem=strict\nProtectHome=true\nReadWritePaths=/var/lib/pgbouncer /var/log/pgbouncer /var/run/pgbouncer\n\n# Resource limits\nLimitNOFILE=65536\n\n[Install]\nWantedBy=multi-user.target\nEOF\n\n  systemctl daemon-reload\n  systemctl enable pgbouncer\n  info \"✓ PgBouncer service configured\"\n}\n\ncreate_pgbouncer_health_endpoint() {\n  info \"Creating PgBouncer health check endpoint\"\n  \n  # Create health check script\n  cat \u003e \"$PGBOUNCER_HEALTH_BIN\" \u003c\u003c'EOF'\n#!/bin/bash\n# PgBouncer Health Check for GCP Load Balancer\nset -euo pipefail\n\nPORT=${1:-8002}\n\n# Function to check PgBouncer status\ncheck_pgbouncer() {\n    # Check if PgBouncer is running\n    if ! systemctl is-active --quiet pgbouncer 2\u003e/dev/null; then\n        return 1\n    fi\n    \n    # Check if PgBouncer is accepting connections\n    if ! timeout 2 bash -c \"\u003c/dev/tcp/localhost/6432\" 2\u003e/dev/null; then\n        return 1\n    fi\n    \n    # Basic connection test through PgBouncer\n    if ! timeout 3 sudo -u postgres psql -h localhost -p 6432 -U postgres -d postgres -c \"SELECT 1\" \u003e/dev/null 2\u003e\u00261; then\n        return 1\n    fi\n    \n    return 0\n}\n\n# Function to handle HTTP request\nhandle_request() {\n    if check_pgbouncer; then\n        status=\"healthy\"\n        http_code=\"200 OK\"\n    else\n        status=\"unhealthy\"\n        http_code=\"503 Service Unavailable\"\n    fi\n    \n    # Get node role\n    role=\"unknown\"\n    if timeout 2 sudo -u postgres psql -Atqc \"SELECT pg_is_in_recovery();\" 2\u003e/dev/null | grep -q '^f'; then\n        role=\"primary\"\n    elif timeout 2 sudo -u postgres psql -Atqc \"SELECT pg_is_in_recovery();\" 2\u003e/dev/null | grep -q '^t'; then\n        role=\"standby\"\n    fi\n    \n    # Create response body\n    body=\"{\\\"service\\\":\\\"pgbouncer\\\",\\\"status\\\":\\\"$status\\\",\\\"role\\\":\\\"$role\\\",\\\"timestamp\\\":\\\"$(date -u +%FT%TZ)\\\",\\\"hostname\\\":\\\"$(hostname)\\\"}\"\n    \n    # Send HTTP response\n    echo -e \"HTTP/1.1 $http_code\\r\\nContent-Type: application/json\\r\\nCache-Control: no-store\\r\\nContent-Length: ${#body}\\r\\nConnection: close\\r\\n\\r\\n$body\"\n}\n\n# Simple HTTP server using socat\nif command -v socat \u003e/dev/null 2\u003e\u00261; then\n    # Use socat if available (more reliable)\n    while true; do\n        handle_request | socat -T 5 TCP-LISTEN:$PORT,reuseaddr,fork STDIO 2\u003e/dev/null || sleep 1\n    done\nelse\n    # Fallback to netcat\n    while true; do\n        handle_request | nc -l -p \"$PORT\" -q 1 \u003e/dev/null 2\u003e\u00261 || sleep 1\n    done\nfi\nEOF\n\n  chmod +x \"$PGBOUNCER_HEALTH_BIN\"\n  \n  # Create systemd service for health endpoint\n  cat \u003e \"/etc/systemd/system/$PGBOUNCER_HEALTH_SERVICE\" \u003c\u003cEOF\n[Unit]\nDescription=PgBouncer Health Check Endpoint\nAfter=network.target pgbouncer.service\nWants=pgbouncer.service\n\n[Service]\nType=simple\nExecStart=$PGBOUNCER_HEALTH_BIN 8002\nRestart=always\nRestartSec=5\nUser=postgres\nGroup=postgres\nNoNewPrivileges=true\n\n[Install]\nWantedBy=multi-user.target\nEOF\n\n  systemctl daemon-reload\n  systemctl enable \"$PGBOUNCER_HEALTH_SERVICE\"\n  info \"✓ PgBouncer health check endpoint created (port 8002)\"\n}\n\nconfigure_postgresql_for_pgbouncer() {\n  info \"Configuring PostgreSQL for PgBouncer with SCRAM-SHA-256 enhanced security\"\n  \n  # Only run if PostgreSQL is accessible\n  if ! sudo -u postgres psql -Atqc 'SELECT 1' postgres \u003e/dev/null 2\u003e\u00261; then\n    warn \"PostgreSQL not accessible, skipping PgBouncer-specific configuration\"\n    return 0\n  fi\n  \n  # Ensure password_encryption is set to scram-sha-256\n  info \"Ensuring SCRAM-SHA-256 password encryption\"\n  sudo -u postgres psql -c \"ALTER SYSTEM SET password_encryption = 'scram-sha-256';\" postgres || warn \"Could not set password encryption\"\n  \n  # Create/update users with SCRAM-SHA-256 passwords\n  info \"Creating/updating users with SCRAM-SHA-256 passwords\"\n  \n  sudo -u postgres psql -c \"\n    DO \\$\\$\n    BEGIN\n      -- Ensure postgres user has SCRAM-SHA-256 password from Secret Manager\n      ALTER ROLE postgres PASSWORD '${PG_SUPER_PASS}';\n      RAISE NOTICE 'Updated postgres user with SCRAM-SHA-256 password';\n      \n      -- Create/update pgbouncer_admin user with limited privileges\n      IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname = 'pgbouncer_admin') THEN\n        CREATE ROLE pgbouncer_admin WITH LOGIN PASSWORD '${PGBOUNCER_PASSWORD}';\n        \n        -- Grant minimal required permissions for PgBouncer admin\n        GRANT CONNECT ON DATABASE postgres TO pgbouncer_admin;\n        GRANT CONNECT ON DATABASE ${REPMGR_DB} TO pgbouncer_admin;\n        GRANT CONNECT ON DATABASE template1 TO pgbouncer_admin;\n        \n        -- Allow basic monitoring queries\n        GRANT pg_monitor TO pgbouncer_admin;\n        \n        -- Grant usage on public schema for basic operations\n        GRANT USAGE ON SCHEMA public TO pgbouncer_admin;\n        \n        RAISE NOTICE 'Created pgbouncer_admin user with SCRAM-SHA-256 password';\n      ELSE\n        -- Update password if user exists\n        ALTER ROLE pgbouncer_admin PASSWORD '${PGBOUNCER_PASSWORD}';\n        RAISE NOTICE 'Updated pgbouncer_admin user with SCRAM-SHA-256 password';\n      END IF;\n      \n      -- Ensure repmgr user has SCRAM-SHA-256 password\n      IF EXISTS (SELECT FROM pg_roles WHERE rolname = '${REPMGR_USER}') THEN\n        ALTER ROLE ${REPMGR_USER} PASSWORD '${REPMGR_PASSWORD}';\n        RAISE NOTICE 'Updated repmgr user with SCRAM-SHA-256 password';\n      END IF;\n    END\n    \\$\\$;\n  \" postgres || warn \"Failed to create/update users with SCRAM-SHA-256 passwords\"\n  \n  # Reload configuration to apply password_encryption setting\n  sudo -u postgres psql -c \"SELECT pg_reload_conf();\" postgres \u003e/dev/null 2\u003e\u00261 || true\n  \n  info \"✓ PostgreSQL configured for PgBouncer with SCRAM-SHA-256 enhanced security\"\n}\n\nstart_pgbouncer_services() {\n  info \"Starting PgBouncer services\"\n  \n  # Start PgBouncer\n  if systemctl start pgbouncer; then\n    info \"✓ PgBouncer started successfully\"\n  else\n    warn \"Failed to start PgBouncer service\"\n    systemctl status pgbouncer || true\n    return 1\n  fi\n  \n  # Start health endpoint\n  if systemctl start \"$PGBOUNCER_HEALTH_SERVICE\"; then\n    info \"✓ PgBouncer health check started successfully\"\n  else\n    warn \"Failed to start PgBouncer health service\"\n    systemctl status \"$PGBOUNCER_HEALTH_SERVICE\" || true\n  fi\n  \n  # Verify services\n  sleep 2\n  if systemctl is-active --quiet pgbouncer; then\n    info \"✓ PgBouncer is running\"\n  else\n    warn \"✗ PgBouncer is not running\"\n    return 1\n  fi\n  \n  # Test connection\n  if timeout 5 bash -c \"\u003c/dev/tcp/localhost/$PGBOUNCER_PORT\" 2\u003e/dev/null; then\n    info \"✓ PgBouncer is accepting connections on port $PGBOUNCER_PORT\"\n  else\n    warn \"✗ PgBouncer connection test failed\"\n  fi\n}\n\nsync_database_passwords() {\n  info \"Synchronizing database passwords with Secret Manager\"\n  \n  # Only run this if PostgreSQL is accessible\n  if ! sudo -u postgres psql -Atqc 'SELECT 1' postgres \u003e/dev/null 2\u003e\u00261; then\n    warn \"PostgreSQL not accessible, skipping password sync\"\n    return 0\n  fi\n  \n  # Create or update repmgr user with correct password from Secret Manager\n  if sudo -u postgres psql -tAc \"SELECT 1 FROM pg_roles WHERE rolname='${REPMGR_USER}'\" postgres | grep -q 1; then\n    info \"Updating repmgr user password to match Secret Manager\"\n    if sudo -u postgres psql -c \"ALTER ROLE ${REPMGR_USER} PASSWORD '${REPMGR_PASSWORD}';\" postgres \u003e/dev/null 2\u003e\u00261; then\n      info \"✓ Repmgr password synchronized successfully\"\n    else\n      warn \"Failed to update repmgr password, but continuing\"\n    fi\n  else\n    info \"Creating repmgr user with Secret Manager password\"\n    if sudo -u postgres psql -c \"CREATE ROLE ${REPMGR_USER} WITH LOGIN SUPERUSER PASSWORD '${REPMGR_PASSWORD}';\" postgres \u003e/dev/null 2\u003e\u00261; then\n      info \"✓ Repmgr user created successfully\"\n    else\n      warn \"Failed to create repmgr user, but continuing\"\n    fi\n  fi\n  \n  # Ensure repmgr database exists\n  if ! sudo -u postgres psql -tAc \"SELECT 1 FROM pg_database WHERE datname='${REPMGR_DB}'\" postgres | grep -q 1; then\n    info \"Creating repmgr database\"\n    sudo -u postgres createdb -O ${REPMGR_USER} ${REPMGR_DB} || warn \"Failed to create repmgr database\"\n  fi\n  \n  # Update replication user password as needed\n  if sudo -u postgres psql -tAc \"SELECT 1 FROM pg_roles WHERE rolname='replication'\" postgres | grep -q 1; then\n    if sudo -u postgres psql -c \"ALTER ROLE replication PASSWORD '${PG_REPL_PASS}';\" postgres \u003e/dev/null 2\u003e\u00261; then\n      debug \"✓ Replication user password synchronized\"\n    fi\n  fi\n  \n  # Test repmgr connection to verify password sync worked\n  local pgpass=\"/var/lib/postgresql/.pgpass\"\n  if [[ -f \"$pgpass\" ]]; then\n    if sudo -u postgres env PGPASSFILE=\"$pgpass\" psql -h localhost -U \"$REPMGR_USER\" -d \"$REPMGR_DB\" -c \"SELECT 'Password sync verified' as status;\" \u003e/dev/null 2\u003e\u00261; then\n      info \"✓ Password synchronization verified successfully\"\n    else\n      warn \"Password synchronization verification failed\"\n    fi\n  fi\n}\n\nsetup_pgpass() {\n  local pgpass=\"/var/lib/postgresql/.pgpass\"\n  info \"Setting up .pgpass file with comprehensive connection entries\"\n  \n  cat \u003e \"$pgpass\" \u003c\u003cEOF\n# Repmgr user entries\nlocalhost:5432:${REPMGR_DB}:${REPMGR_USER}:${REPMGR_PASSWORD}\n${REPMGR_PRIMARY_HOST}:5432:${REPMGR_DB}:${REPMGR_USER}:${REPMGR_PASSWORD}\nlocalhost:5432:replication:${REPMGR_USER}:${REPMGR_PASSWORD}\n${REPMGR_PRIMARY_HOST}:5432:replication:${REPMGR_USER}:${REPMGR_PASSWORD}\nEOF\n\n  if [[ -n \"$SELF_IP\" \u0026\u0026 \"$SELF_IP\" != \"localhost\" \u0026\u0026 \"$SELF_IP\" != \"$REPMGR_PRIMARY_HOST\" ]]; then\n    cat \u003e\u003e \"$pgpass\" \u003c\u003cEOF\n${SELF_IP}:5432:${REPMGR_DB}:${REPMGR_USER}:${REPMGR_PASSWORD}\n${SELF_IP}:5432:replication:${REPMGR_USER}:${REPMGR_PASSWORD}\nEOF\n  fi\n\n  # Add postgres user entries for PgBouncer connectivity\n  cat \u003e\u003e \"$pgpass\" \u003c\u003cEOF\n\n# Postgres user entries for PgBouncer\nlocalhost:5432:*:postgres:${PG_SUPER_PASS}\n${REPMGR_PRIMARY_HOST}:5432:*:postgres:${PG_SUPER_PASS}\nlocalhost:6432:*:postgres:${PG_SUPER_PASS}\n${REPMGR_PRIMARY_HOST}:6432:*:postgres:${PG_SUPER_PASS}\nEOF\n\n  if [[ -n \"$SELF_IP\" \u0026\u0026 \"$SELF_IP\" != \"localhost\" \u0026\u0026 \"$SELF_IP\" != \"$REPMGR_PRIMARY_HOST\" ]]; then\n    cat \u003e\u003e \"$pgpass\" \u003c\u003cEOF\n${SELF_IP}:5432:*:postgres:${PG_SUPER_PASS}\n${SELF_IP}:6432:*:postgres:${PG_SUPER_PASS}\nEOF\n  fi\n\n  # Add PgBouncer admin entries (enhanced security)\n  cat \u003e\u003e \"$pgpass\" \u003c\u003cEOF\n\n# PgBouncer admin user entries (enhanced security)\nlocalhost:6432:pgbouncer:pgbouncer_admin:${PGBOUNCER_PASSWORD}\n${REPMGR_PRIMARY_HOST}:6432:pgbouncer:pgbouncer_admin:${PGBOUNCER_PASSWORD}\nEOF\n\n  if [[ -n \"$SELF_IP\" \u0026\u0026 \"$SELF_IP\" != \"localhost\" \u0026\u0026 \"$SELF_IP\" != \"$REPMGR_PRIMARY_HOST\" ]]; then\n    cat \u003e\u003e \"$pgpass\" \u003c\u003cEOF\n${SELF_IP}:6432:pgbouncer:pgbouncer_admin:${PGBOUNCER_PASSWORD}\nEOF\n  fi\n\n  # Add wildcard entries for better connectivity\n  cat \u003e\u003e \"$pgpass\" \u003c\u003cEOF\n\n# Wildcard entries\n*:5432:${REPMGR_DB}:${REPMGR_USER}:${REPMGR_PASSWORD}\n*:5432:replication:${REPMGR_USER}:${REPMGR_PASSWORD}\n*:5432:*:postgres:${PG_SUPER_PASS}\n*:6432:*:postgres:${PG_SUPER_PASS}\n*:6432:pgbouncer:pgbouncer_admin:${PGBOUNCER_PASSWORD}\nEOF\n\n  chown postgres:postgres \"$pgpass\" || true\n  chmod 600 \"$pgpass\" || true\n  debug \".pgpass configured with $(wc -l \u003c \"$pgpass\") entries\"\n}\n\n# ============================================================================\n# PACKAGE INSTALLATION\n# ============================================================================\n\ninstall_packages() {\n  info \"Installing required packages\"\n  export DEBIAN_FRONTEND=noninteractive\n  \n  # Update package list\n  retry 3 5 apt-get update || die \"apt update failed\"\n  \n  # Install base packages\n  local base_pkgs=(wget gnupg lsb-release jq netcat-openbsd curl ca-certificates openssl)\n  retry 3 5 apt-get install -y --no-install-recommends \"${base_pkgs[@]}\" || die \"base packages install failed\"\n\n  # Add PostgreSQL official repository\n  if [[ ! -f /etc/apt/sources.list.d/pgdg.list ]]; then\n    echo \"deb http://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main\" \u003e /etc/apt/sources.list.d/pgdg.list\n    wget -qO - https://www.postgresql.org/media/keys/ACCC4CF8.asc | gpg --dearmor \u003e /etc/apt/trusted.gpg.d/pgdg.gpg\n    info \"PostgreSQL official repository added\"\n    retry 3 5 apt-get update || die \"apt update after PGDG failed\"\n  fi\n\n  # Install PostgreSQL and related packages\n  local pg_pkgs=()\n  for p in postgresql-${PG_VERSION} postgresql-client-${PG_VERSION} pgbouncer; do\n    if ! dpkg -s \"$p\" \u003e/dev/null 2\u003e\u00261; then pg_pkgs+=(\"$p\"); fi\n  done\n  \n  if ((${#pg_pkgs[@]})); then\n    retry 3 5 apt-get install -y \"${pg_pkgs[@]}\" || die \"PostgreSQL packages install failed\"\n  fi\n\n  # Install repmgr\n  if ! command -v repmgr \u003e/dev/null 2\u003e\u00261; then\n    info \"Installing repmgr\"\n    if apt-cache show repmgr \u003e/dev/null 2\u003e\u00261; then\n      apt-get install -y repmgr || die \"repmgr install failed\"\n    else\n      die \"repmgr package not available\"\n    fi\n  fi\n\n  # Set proper ownership\n  if id -u postgres \u003e/dev/null 2\u003e\u00261; then\n    chown -R postgres:postgres \"$REPMGR_CONF_DIR\" \"$REPMGR_EVENTS_DIR\" || true\n    chmod 750 \"$REPMGR_CONF_DIR\" \"$REPMGR_EVENTS_DIR\" || true\n  fi\n  \n  info \"Package installation completed\"\n}\n\n# ============================================================================\n# POSTGRESQL CONFIGURATION\n# ============================================================================\n\nconfigure_postgresql() {\n  info \"Configuring PostgreSQL\"\n  \n  # Determine config file paths\n  local pg_conf pg_hba\n  if [[ -f \"/etc/postgresql/${PG_VERSION}/${PG_CLUSTER_NAME}/postgresql.conf\" ]]; then\n    pg_conf=\"/etc/postgresql/${PG_VERSION}/${PG_CLUSTER_NAME}/postgresql.conf\"\n    pg_hba=\"/etc/postgresql/${PG_VERSION}/${PG_CLUSTER_NAME}/pg_hba.conf\"\n  else\n    pg_conf=\"${PG_DATA_DIR}/postgresql.conf\"\n    pg_hba=\"${PG_DATA_DIR}/pg_hba.conf\"\n  fi\n  \n  # Configure postgresql.conf for HA\n  if ! grep -q '^wal_level' \"$pg_conf\" 2\u003e/dev/null; then\n    cat \u003e\u003e \"$pg_conf\" \u003c\u003cEOF\n# PostgreSQL HA Configuration\nlisten_addresses = '*'\nwal_level = replica\nmax_wal_senders = 10\nwal_keep_size = '1024MB'\nhot_standby = on\nshared_preload_libraries = 'repmgr'\narchive_mode = off\n# Performance tuning\nshared_buffers = 128MB\neffective_cache_size = 1GB\nEOF\n    info \"Added HA configuration to postgresql.conf\"\n  fi\n  \n  configure_pg_hba \"$pg_hba\"\n}\n\nconfigure_pg_hba() {\n  local pg_hba=\"$1\"\n  info \"Configuring pg_hba.conf for SCRAM-SHA-256 cluster access\"\n  \n  # Always use SCRAM-SHA-256 for enhanced security\n  local auth_method=\"scram-sha-256\"\n  \n  # Detect network CIDR\n  local allow_cidr=\"192.168.0.0/16\"\n  if [[ -n \"$SELF_IP\" ]]; then\n    case \"$SELF_IP\" in\n      10.*) allow_cidr=\"10.0.0.0/8\" ;;\n      192.168.*) allow_cidr=\"192.168.0.0/16\" ;;\n      172.1[6-9].*|172.2[0-9].*|172.3[01].*) allow_cidr=\"172.16.0.0/12\" ;;\n      *) allow_cidr=\"${SELF_IP%.*}.0/24\" ;;\n    esac\n  fi\n  \n  # Add comprehensive pg_hba.conf entries with SCRAM-SHA-256\n  if ! grep -q '# HA-CLUSTER-SCRAM-HBA' \"$pg_hba\" 2\u003e/dev/null; then\n    cat \u003e\u003e \"$pg_hba\" \u003c\u003cEOF\n# HA-CLUSTER-SCRAM-HBA (managed by bootstrap script)\nlocal   all             all                                     peer\nhost    all             all             127.0.0.1/32            ${auth_method}\nhost    all             all             ::1/128                 ${auth_method}\n\n# PgBouncer SCRAM-SHA-256 authentication entries\nhost    all             postgres        127.0.0.1/32            ${auth_method}\nhost    all             postgres        ::1/128                 ${auth_method}\nhost    all             pgbouncer_admin 127.0.0.1/32            ${auth_method}\nhost    all             pgbouncer_admin ::1/128                 ${auth_method}\n\n# Replication connections\nhost    replication     replication     ${allow_cidr}           ${auth_method}\nhost    replication     ${REPMGR_USER}  ${allow_cidr}           ${auth_method}\n\n# Repmgr database connections  \nhost    ${REPMGR_DB}    ${REPMGR_USER}  ${allow_cidr}           ${auth_method}\nhost    all             ${REPMGR_USER}  ${allow_cidr}           ${auth_method}\nEOF\n    info \"Added SCRAM-SHA-256 cluster access rules to pg_hba.conf (CIDR: $allow_cidr)\"\n  fi\n  \n  # Add specific IP entries\n  local changed=0\n  for ip in \"$SELF_IP\" \"$REPMGR_PRIMARY_HOST\"; do\n    if [[ -n \"$ip\" \u0026\u0026 \"$ip\" != \"localhost\" \u0026\u0026 \"$ip\" != \"pg-primary\" ]]; then\n      if ! grep -qE \"^host\\\\s+${REPMGR_DB}\\\\s+${REPMGR_USER}\\\\s+${ip}/32\" \"$pg_hba\" 2\u003e/dev/null; then\n        cat \u003e\u003e \"$pg_hba\" \u003c\u003cEOF\n# Specific SCRAM entries for ${ip}\nhost    ${REPMGR_DB}    ${REPMGR_USER}  ${ip}/32                ${auth_method}\nhost    replication     replication     ${ip}/32                ${auth_method}\nhost    replication     ${REPMGR_USER}  ${ip}/32                ${auth_method}\nhost    all             postgres        ${ip}/32                ${auth_method}\nhost    all             pgbouncer_admin ${ip}/32                ${auth_method}\nEOF\n        changed=1\n      fi\n    fi\n  done\n  \n  if (( changed == 1 )); then\n    info \"Added specific SCRAM-SHA-256 IP entries to pg_hba.conf\"\n  fi\n}\n\ngenerate_repmgr_conf() {\n  info \"Generating repmgr configuration\"\n  \n  local node_id\n  case \"$ROLE\" in\n    primary) node_id=1 ;;\n    standby) node_id=2 ;;\n    witness) node_id=9 ;;\n    *) node_id=0 ;;\n  esac\n  \n  local cluster_name\n  cluster_name=$(echo \"${CLUSTER_ID}\" | tr 'A-Z' 'a-z' | sed 's/[^a-z0-9_]/_/g')\n  \n  local conninfo_host=\"$SELF_IP\"\n  [[ -z \"$conninfo_host\" ]] \u0026\u0026 conninfo_host=\"localhost\"\n  \n  cat \u003e \"$REPMGR_CONF_FILE\" \u003c\u003cEOF\n# Repmgr configuration for ${ROLE} node\nnode_id=${node_id}\nnode_name='${ROLE}'\nconninfo='host=${conninfo_host} user=${REPMGR_USER} dbname=${REPMGR_DB}'\ndata_directory='${PG_DATA_DIR}'\npg_bindir='/usr/lib/postgresql/${PG_VERSION}/bin'\n\n# Replication settings\nuse_replication_slots=yes\n\n# Logging\nlog_file='${REPMGR_LOG_DIR}/repmgrd.log'\nlog_level=INFO\n\n# Monitoring and failover\nmonitor_interval_secs=5\nfailover=automatic\npromote_command='repmgr standby promote -f ${REPMGR_CONF_FILE}'\nfollow_command='repmgr standby follow -f ${REPMGR_CONF_FILE} --upstream-node-id=%n'\n\n# Timeouts and reconnection\nprimary_follow_timeout=60\nreconnect_attempts=6\nreconnect_interval=5\n\n# Event notifications\nevent_notifications=all\nevent_notification_command='${REPMGR_EVENTS_DIR}/exec.sh %n %e %s %t %d %p %r'\nEOF\n\n  chown postgres:postgres \"$REPMGR_CONF_FILE\" || true\n  chmod 640 \"$REPMGR_CONF_FILE\" || true\n  info \"Repmgr configuration generated (node_id=$node_id, cluster=$cluster_name)\"\n}\n\n# ============================================================================\n# ROLE-SPECIFIC INITIALIZATION\n# ============================================================================\n\ninit_primary() {\n  if [[ -f $SENTINEL_PRIMARY_INIT ]]; then\n    info \"Primary already initialized\"\n    return 0\n  fi\n  \n  info \"Initializing primary node\"\n  \n  # Enable and configure PostgreSQL\n  systemctl enable postgresql || true\n  systemctl stop postgresql || true\n  configure_postgresql\n  systemctl start postgresql || true\n  \n  # Wait for PostgreSQL to be ready\n  retry 15 2 sudo -u postgres psql -Atqc 'select 1' postgres || die \"PostgreSQL not responding\"\n  \n  # Ensure listen_addresses is set to '*'\n  local current_listen\n  current_listen=$(sudo -u postgres psql -Atqc \"show listen_addresses\" 2\u003e/dev/null || echo '')\n  if [[ \"$current_listen\" != \"*\" ]]; then\n    info \"Setting listen_addresses to '*'\"\n    sudo -u postgres psql -c \"ALTER SYSTEM SET listen_addresses = '*';\" || true\n    systemctl restart postgresql || true\n    retry 10 2 sudo -u postgres psql -Atqc 'select 1' postgres || die \"PostgreSQL not responding after restart\"\n  fi\n  \n  # Create repmgr user and database\n  sudo -u postgres psql -tAc \"SELECT 1 FROM pg_roles WHERE rolname='${REPMGR_USER}'\" postgres | grep -q 1 || \\\n    sudo -u postgres psql -c \"CREATE ROLE ${REPMGR_USER} WITH LOGIN SUPERUSER PASSWORD '${REPMGR_PASSWORD}';\" postgres\n  \n  sudo -u postgres psql -tAc \"SELECT 1 FROM pg_database WHERE datname='${REPMGR_DB}'\" postgres | grep -q 1 || \\\n    sudo -u postgres createdb -O ${REPMGR_USER} ${REPMGR_DB}\n  \n  sudo -u postgres psql -tAc \"SELECT 1 FROM pg_roles WHERE rolname='replication'\" postgres | grep -q 1 || \\\n    sudo -u postgres psql -c \"CREATE ROLE replication WITH REPLICATION LOGIN ENCRYPTED PASSWORD '${PG_REPL_PASS}';\" postgres\n  \n  # Create replication slots\n  ensure_replication_slots\n  \n  # Reload PostgreSQL to apply pg_hba.conf changes\n  systemctl reload postgresql || true\n  \n  touch \"$SENTINEL_PRIMARY_INIT\"\n  info \"Primary node initialization completed\"\n}\n\ninit_standby() {\n  if [[ -f $SENTINEL_STANDBY_CLONED ]]; then\n    info \"Standby already cloned\"\n    return 0\n  fi\n  \n  info \"Initializing standby node\"\n  \n  # Wait for primary to be available\n  local max_wait=30 wait_interval=5 attempt=0\n  info \"Waiting for primary $REPMGR_PRIMARY_HOST to be available\"\n  while (( attempt \u003c max_wait )); do\n    if nc -z \"$REPMGR_PRIMARY_HOST\" 5432 2\u003e/dev/null; then\n      info \"Primary is reachable\"\n      break\n    fi\n    sleep $wait_interval\n    attempt=$((attempt + 1))\n  done\n  \n  if (( attempt \u003e= max_wait )); then\n    die \"Primary $REPMGR_PRIMARY_HOST not reachable after ${max_wait} attempts\"\n  fi\n  \n  # Stop PostgreSQL and clean data directory\n  systemctl stop postgresql || true\n  mkdir -p \"${PG_DATA_DIR}\" \u0026\u0026 chown -R postgres:postgres \"${PG_DATA_DIR}\" || true\n  find \"${PG_DATA_DIR}\" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2\u003e/dev/null || true\n  \n  # Setup authentication\n  setup_pgpass\n  \n  # Clone from primary\n  local clone_log=\"$LOG_DIR/repmgr_clone.log\"\n  info \"Cloning standby from primary $REPMGR_PRIMARY_HOST\"\n  \n  # Test connectivity first\n  info \"Testing connection to primary before cloning...\"\n  if ! sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass psql -h \"$REPMGR_PRIMARY_HOST\" -U \"$REPMGR_USER\" -d \"$REPMGR_DB\" -c \"SELECT 1\" \u003e/dev/null 2\u003e\u00261; then\n    warn \"Cannot connect to repmgr database on primary. Checking if primary is properly initialized...\"\n    \n    # Wait a bit more for primary to be fully ready\n    info \"Waiting additional time for primary to complete initialization...\"\n    sleep 10\n    \n    if ! sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass psql -h \"$REPMGR_PRIMARY_HOST\" -U \"$REPMGR_USER\" -d \"$REPMGR_DB\" -c \"SELECT 1\" \u003e/dev/null 2\u003e\u00261; then\n      error \"Still cannot connect to primary repmgr database\"\n      info \"Testing basic PostgreSQL connection...\"\n      sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass psql -h \"$REPMGR_PRIMARY_HOST\" -U postgres -d postgres -c \"SELECT version()\" || true\n      die \"Primary is not ready for replication setup\"\n    fi\n  fi\n  \n  if sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass \\\n     repmgr -h \"$REPMGR_PRIMARY_HOST\" -U \"$REPMGR_USER\" -d \"$REPMGR_DB\" -f \"$REPMGR_CONF_FILE\" \\\n     standby clone \u003e \"$clone_log\" 2\u003e\u00261; then\n    info \"Standby clone completed successfully\"\n  else\n    error \"Standby clone failed. Log contents:\"\n    cat \"$clone_log\" \u003e\u003e \"$LOG_FILE\"\n    info \"Current .pgpass contents (passwords hidden):\"\n    sed 's/:[^:]*$/:*****/' /var/lib/postgresql/.pgpass \u003e\u003e \"$LOG_FILE\"\n    die \"Standby clone failed\"\n  fi\n  \n  # Configure pg_hba.conf for standby-specific access\n  configure_postgresql\n  \n  # Start PostgreSQL\n  systemctl start postgresql || die \"Failed to start PostgreSQL after clone\"\n  \n  # Wait for standby to be ready\n  retry 10 2 sudo -u postgres psql -Atqc 'select pg_is_in_recovery()' postgres || die \"Standby not responding\"\n  \n  # Verify standby is in recovery mode\n  if sudo -u postgres psql -Atqc 'select pg_is_in_recovery()' postgres 2\u003e/dev/null | grep -q 't'; then\n    info \"Standby is correctly in recovery mode\"\n  else\n    warn \"Standby might not be in recovery mode\"\n  fi\n  \n  touch \"$SENTINEL_STANDBY_CLONED\"\n  info \"Standby node initialization completed\"\n}\n\nensure_replication_slots() {\n  [[ \"$ROLE\" != \"primary\" ]] \u0026\u0026 return 0\n  \n  info \"Ensuring replication slots exist\"\n  local cluster_sanitized\n  cluster_sanitized=$(echo \"$CLUSTER_ID\" | tr 'A-Z' 'a-z' | sed 's/[^a-z0-9_]/_/g')\n  \n  # Create primary replication slot\n  local slot_name=\"${cluster_sanitized}_standby_1\"\n  if ! sudo -u postgres psql -Atqc \"select slot_name from pg_replication_slots where slot_name='${slot_name}'\" postgres | grep -q \"${slot_name}\"; then\n    sudo -u postgres psql -c \"select * from pg_create_physical_replication_slot('${slot_name}');\" postgres || warn \"Failed creating slot $slot_name\"\n  fi\n  \n  # Create repmgr slot\n  local repmgr_slot=\"repmgr_slot_2\"\n  if ! sudo -u postgres psql -Atqc \"select slot_name from pg_replication_slots where slot_name='${repmgr_slot}'\" postgres | grep -q \"${repmgr_slot}\"; then\n    sudo -u postgres psql -c \"select * from pg_create_physical_replication_slot('${repmgr_slot}');\" postgres || warn \"Failed creating slot $repmgr_slot\"\n  fi\n  \n  info \"Replication slots ensured\"\n}\n\n# ============================================================================\n# CLUSTER REGISTRATION AND SERVICES\n# ============================================================================\n\nregister_node() {\n  info \"Registering node with repmgr cluster\"\n  \n  # Setup authentication first\n  setup_pgpass\n  \n  local register_cmd\n  case \"$ROLE\" in\n    primary)\n      register_cmd=\"sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f $REPMGR_CONF_FILE primary register --force\"\n      ;;\n    standby)\n      register_cmd=\"sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f $REPMGR_CONF_FILE standby register --force\"\n      ;;\n    witness)\n      register_cmd=\"sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f $REPMGR_CONF_FILE witness register --force\"\n      ;;\n    *)\n      warn \"Unknown role $ROLE, skipping registration\"\n      return 0\n      ;;\n  esac\n\n  local register_log=\"$LOG_DIR/repmgr_register.log\"\n  if $register_cmd \u003e \"$register_log\" 2\u003e\u00261; then\n    info \"Node registration completed successfully\"\n  else\n    warn \"Node registration failed, checking log...\"\n    cat \"$register_log\" \u003e\u003e \"$LOG_FILE\"\n    # For primary nodes, try to register with force if database exists\n    if [[ \"$ROLE\" == \"primary\" ]]; then\n      info \"Attempting to re-initialize repmgr database on primary\"\n      if sudo -u postgres psql -d \"$REPMGR_DB\" -c \"SELECT 1\" \u003e/dev/null 2\u003e\u00261; then\n        info \"Clearing existing repmgr tables...\"\n        sudo -u postgres psql -d \"$REPMGR_DB\" -c \"DROP TABLE IF EXISTS repmgr.nodes CASCADE;\" 2\u003e/dev/null || true\n        sudo -u postgres psql -d \"$REPMGR_DB\" -c \"DROP SCHEMA IF EXISTS repmgr CASCADE;\" 2\u003e/dev/null || true\n        \n        if sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f \"$REPMGR_CONF_FILE\" primary register --force \u003e \"$register_log\" 2\u003e\u00261; then\n          info \"Primary re-registration successful\"\n        else\n          warn \"Primary re-registration failed, but continuing\"\n          cat \"$register_log\" \u003e\u003e \"$LOG_FILE\"\n        fi\n      fi\n    else\n      warn \"Registration failed, but continuing\"\n    fi\n  fi\n  \n  # Verify cluster status\n  if sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f \"$REPMGR_CONF_FILE\" cluster show \u003e/dev/null 2\u003e\u00261; then\n    info \"Cluster status verification successful\"\n    sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f \"$REPMGR_CONF_FILE\" cluster show | head -10 \u003e\u003e \"$LOG_FILE\"\n  else\n    warn \"Cluster status verification failed\"\n  fi\n}\n\ndeploy_event_hooks() {\n  info \"Deploying event notification hooks\"\n  \n  mkdir -p \"$REPMGR_EVENTS_DIR\"\n  cat \u003e \"${REPMGR_EVENTS_DIR}/exec.sh\" \u003c\u003c'EOF'\n#!/bin/bash\n# Repmgr event notification handler\nset -euo pipefail\n\nEVT=\"$1\"; shift || true\nROLE_STATE=\"unknown\"; REC=\"unknown\"\n\n# Determine current role\nif psql -U postgres -d postgres -Atqc 'select 1' \u003e/dev/null 2\u003e\u00261; then\n  REC=$(psql -U postgres -d postgres -Atqc 'select pg_is_in_recovery()' 2\u003e/dev/null || echo unknown)\n  [[ \"$REC\" == \"f\" ]] \u0026\u0026 ROLE_STATE=primary || ROLE_STATE=standby\nfi\n\n# Create event payload\nPAYLOAD=$(jq -n \\\n  --arg evt \"$EVT\" \\\n  --arg role \"$ROLE_STATE\" \\\n  --arg rec \"$REC\" \\\n  --arg ts \"$(date -u +%FT%TZ)\" \\\n  --arg host \"$(hostname)\" \\\n  '{timestamp:$ts,event:$evt,role:$role,is_in_recovery:$rec,hostname:$host}')\n\n# Log event\necho \"$PAYLOAD\" \u003e\u003e /var/log/repmgr/events.log\n\n# Rotate log if it gets too large\nif [[ -f /var/log/repmgr/events.log ]] \u0026\u0026 [[ $(stat -f%z /var/log/repmgr/events.log 2\u003e/dev/null || stat -c%s /var/log/repmgr/events.log) -gt 10485760 ]]; then\n  mv /var/log/repmgr/events.log /var/log/repmgr/events.log.old\nfi\n\nexit 0\nEOF\n  \n  chmod +x \"${REPMGR_EVENTS_DIR}/exec.sh\" || true\n  chown postgres:postgres \"${REPMGR_EVENTS_DIR}/exec.sh\" || true\n  info \"Event hooks deployed\"\n}\n\nsetup_health_endpoint() {\n  info \"Setting up health endpoint service\"\n  \n  # Create health check script\n  cat \u003e \"$HEALTH_BIN\" \u003c\u003cEOF\n#!/bin/bash\n# PostgreSQL HA Health Endpoint\nset -euo pipefail\n\nPORT=${HEALTH_PORT}\nNC_BIN=\"/usr/bin/nc\"\n\nwhile true; do\n  role=\"unknown\"\n  rec=\"unknown\"\n  status=\"unhealthy\"\n  \n  # Check PostgreSQL connectivity and role\n  if psql -U postgres -d postgres -Atqc 'select 1' \u003e/dev/null 2\u003e\u00261; then\n    rec=\\$(psql -U postgres -d postgres -Atqc 'select pg_is_in_recovery()' 2\u003e/dev/null || echo unknown)\n    if [[ \"\\$rec\" == \"f\" ]]; then\n      role=\"primary\"\n      status=\"healthy\"\n    elif [[ \"\\$rec\" == \"t\" ]]; then\n      role=\"standby\"\n      status=\"healthy\"\n    fi\n  fi\n  \n  # Create response body\n  body=\"{\\\"role\\\":\\\"\\$role\\\",\\\"status\\\":\\\"\\$status\\\",\\\"is_in_recovery\\\":\\\"\\$rec\\\",\\\"timestamp\\\":\\\"\\$(date -u +%FT%TZ)\\\",\\\"hostname\\\":\\\"\\$(hostname)\\\"}\"\n  \n  # Send HTTP response\n  printf 'HTTP/1.1 200 OK\\r\\nContent-Type: application/json\\r\\nCache-Control: no-store\\r\\nContent-Length: %s\\r\\n\\r\\n%s' \"\\${#body}\" \"\\$body\" | \"\\$NC_BIN\" -l -p \"\\$PORT\" -q 1 \u003e/dev/null 2\u003e\u00261 || sleep 1\ndone\nEOF\n  \n  chmod +x \"$HEALTH_BIN\"\n  \n  # Create systemd service\n  cat \u003e \"/etc/systemd/system/${HEALTH_SERVICE}\" \u003c\u003cEOF\n[Unit]\nDescription=PostgreSQL HA Health Endpoint\nAfter=network.target postgresql.service\nWants=postgresql.service\n\n[Service]\nType=simple\nExecStart=${HEALTH_BIN}\nRestart=always\nRestartSec=5\nUser=postgres\nGroup=postgres\nNoNewPrivileges=true\nPrivateTmp=true\n\n[Install]\nWantedBy=multi-user.target\nEOF\n  \n  # Enable and start service\n  systemctl daemon-reload || true\n  systemctl enable ${HEALTH_SERVICE} || true\n  systemctl restart ${HEALTH_SERVICE} || true\n  \n  info \"Health endpoint service configured on port $HEALTH_PORT\"\n}\n\nstart_repmgrd() {\n  info \"Starting repmgrd monitoring service\"\n  \n  systemctl enable repmgrd || true\n  systemctl restart repmgrd || true\n  \n  # Verify service is running\n  if systemctl is-active --quiet repmgrd; then\n    info \"repmgrd service is running\"\n  else\n    warn \"repmgrd service failed to start\"\n  fi\n}\n\n# ============================================================================\n# POST-DEPLOYMENT VALIDATION\n# ============================================================================\n\nvalidate_deployment() {\n  info \"Validating deployment\"\n  local errors=0\n  \n  # Check PostgreSQL\n  if systemctl is-active --quiet postgresql; then\n    info \"✓ PostgreSQL service is running\"\n  else\n    error \"✗ PostgreSQL service is not running\"\n    errors=$((errors + 1))\n  fi\n  \n  # Check database connectivity\n  if sudo -u postgres psql -Atqc 'select 1' postgres \u003e/dev/null 2\u003e\u00261; then\n    info \"✓ PostgreSQL database is accessible\"\n  else\n    error \"✗ PostgreSQL database is not accessible\"\n    errors=$((errors + 1))\n  fi\n  \n  # Check role\n  local is_recovery\n  is_recovery=$(sudo -u postgres psql -Atqc 'select pg_is_in_recovery()' postgres 2\u003e/dev/null || echo unknown)\n  if [[ \"$ROLE\" == \"primary\" \u0026\u0026 \"$is_recovery\" == \"f\" ]]; then\n    info \"✓ Node is correctly configured as primary\"\n  elif [[ \"$ROLE\" == \"standby\" \u0026\u0026 \"$is_recovery\" == \"t\" ]]; then\n    info \"✓ Node is correctly configured as standby\"\n  else\n    error \"✗ Node role mismatch (expected: $ROLE, recovery: $is_recovery)\"\n    errors=$((errors + 1))\n  fi\n  \n  # Check repmgr\n  if command -v repmgr \u003e/dev/null 2\u003e\u00261; then\n    info \"✓ repmgr is installed\"\n  else\n    error \"✗ repmgr is not installed\"\n    errors=$((errors + 1))\n  fi\n  \n  # Check repmgrd service\n  if systemctl is-active --quiet repmgrd; then\n    info \"✓ repmgrd service is running\"\n  else\n    warn \"✗ repmgrd service is not running\"\n  fi\n  \n  # Check health endpoint\n  if systemctl is-active --quiet ${HEALTH_SERVICE}; then\n    info \"✓ Health endpoint service is running\"\n  else\n    warn \"✗ Health endpoint service is not running\"\n  fi\n  \n  # Test health endpoint\n  if timeout 5 curl -s \"http://localhost:${HEALTH_PORT}\" \u003e/dev/null 2\u003e\u00261; then\n    info \"✓ Health endpoint is responding\"\n  else\n    warn \"✗ Health endpoint is not responding\"\n  fi\n  \n  # Check PgBouncer\n  if command -v pgbouncer \u003e/dev/null 2\u003e\u00261; then\n    info \"✓ PgBouncer is installed\"\n    \n    # Check PgBouncer service\n    if systemctl is-active --quiet pgbouncer; then\n      info \"✓ PgBouncer service is running\"\n    else\n      warn \"✗ PgBouncer service is not running\"\n    fi\n    \n    # Test PgBouncer connection\n    if timeout 5 bash -c \"\u003c/dev/tcp/localhost/$PGBOUNCER_PORT\" 2\u003e/dev/null; then\n      info \"✓ PgBouncer is accepting connections\"\n    else\n      warn \"✗ PgBouncer is not accepting connections\"\n    fi\n    \n    # Test PgBouncer health endpoint\n    if timeout 5 curl -s \"http://localhost:8002\" \u003e/dev/null 2\u003e\u00261; then\n      info \"✓ PgBouncer health endpoint is responding\"\n    else\n      warn \"✗ PgBouncer health endpoint is not responding\"\n    fi\n  else\n    warn \"✗ PgBouncer is not installed\"\n  fi\n  \n  # Check cluster status (best effort)\n  if sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f \"$REPMGR_CONF_FILE\" cluster show \u003e/dev/null 2\u003e\u00261; then\n    info \"✓ Repmgr cluster status is available\"\n  else\n    warn \"✗ Repmgr cluster status is not available (may be normal during initial setup)\"\n  fi\n  \n  if (( errors == 0 )); then\n    info \"✓ Deployment validation completed successfully\"\n    return 0\n  else\n    error \"✗ Deployment validation failed with $errors errors\"\n    return 1\n  fi\n}\n\n# ============================================================================\n# MAIN BOOTSTRAP LOGIC\n# ============================================================================\n\nmain() {\n  local start_time end_time duration\n  start_time=$(date +%s)\n  \n  info \"=========================================\"\n  info \"PostgreSQL HA Cluster Bootstrap Started\"\n  info \"Version: $SCRIPT_VERSION\"\n  info \"=========================================\"\n  \n  # Check if already bootstrapped\n  if [[ -f $SENTINEL_BOOTSTRAP ]]; then\n    info \"Bootstrap already completed (sentinel found)\"\n    info \"Running post-deployment validation...\"\n    # Re-detect configuration for validation\n    detect_configuration\n    validate_deployment || warn \"Validation issues detected\"\n    return 0\n  fi\n  \n  # Main bootstrap sequence\n  info \"Step 1/13: Detecting configuration...\"\n  detect_configuration\n  \n  # Auto-fix password for standby nodes before loading secrets\n  auto_fix_repmgr_password\n  \n  info \"Step 2/13: Loading secrets...\"\n  load_secrets\n  \n  info \"Step 3/13: Installing packages...\"\n  install_packages\n  \n  info \"Step 4/13: Synchronizing database passwords...\"\n  sync_database_passwords\n  \n  info \"Step 5/13: Generating repmgr configuration...\"\n  generate_repmgr_conf\n  \n  info \"Step 6/13: Role-specific initialization ($ROLE)...\"\n  case \"$ROLE\" in\n    primary)\n      init_primary\n      ;;\n    standby)\n      init_standby\n      ;;\n    witness)\n      # Witness node setup - minimal PostgreSQL installation\n      info \"Witness node setup - starting PostgreSQL service\"\n      systemctl enable postgresql || true\n      systemctl start postgresql || true\n      ;;\n    *)\n      die \"Unknown role: $ROLE\"\n      ;;\n  esac\n  \n  info \"Step 7/13: Setting up authentication...\"\n  setup_pgpass\n  \n  info \"Step 8/13: Registering node with cluster...\"\n  register_node\n  \n  info \"Step 9/13: Deploying event hooks...\"\n  deploy_event_hooks\n  \n  info \"Step 10/16: Installing PgBouncer...\"\n  install_pgbouncer\n  \n  info \"Step 11/16: Configuring PgBouncer...\"\n  configure_pgbouncer\n  create_pgbouncer_userlist\n  setup_pgbouncer_service\n  \n  info \"Step 12/16: Creating PgBouncer health endpoint...\"\n  create_pgbouncer_health_endpoint\n  \n  info \"Step 13/16: Setting up PostgreSQL health endpoint...\"\n  setup_health_endpoint\n  \n  info \"Step 14/16: Starting repmgrd service...\"\n  start_repmgrd\n  \n  info \"Step 15/16: Starting PgBouncer services...\"\n  configure_postgresql_for_pgbouncer\n  start_pgbouncer_services || warn \"PgBouncer startup had issues\"\n  \n  info \"Step 16/16: Running deployment validation...\"\n  validate_deployment || warn \"Validation issues detected\"\n  \n  info \"Step 17/17: Finalizing bootstrap...\"\n  touch \"$SENTINEL_BOOTSTRAP\"\n  \n  end_time=$(date +%s)\n  duration=$((end_time - start_time))\n  \n  info \"=========================================\"\n  info \"PostgreSQL HA Cluster Bootstrap Complete\"\n  info \"Role: $ROLE\"\n  info \"Duration: ${duration} seconds\"\n  info \"Health endpoint: http://$(hostname -I | awk '{print $1}'):${HEALTH_PORT}\"\n  info \"=========================================\"\n  \n  # Final cluster status\n  if sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f \"$REPMGR_CONF_FILE\" cluster show 2\u003e/dev/null; then\n    info \"Final cluster status:\"\n    sudo -u postgres env PGPASSFILE=/var/lib/postgresql/.pgpass repmgr -f \"$REPMGR_CONF_FILE\" cluster show\n  fi\n}\n\n# ============================================================================\n# SCRIPT EXECUTION\n# ============================================================================\n\n# Ensure running as root\nif [[ $EUID -ne 0 ]]; then\n  die \"This script must be run as root\"\nfi\n\n# Execute main function\nmain \"$@\"",
