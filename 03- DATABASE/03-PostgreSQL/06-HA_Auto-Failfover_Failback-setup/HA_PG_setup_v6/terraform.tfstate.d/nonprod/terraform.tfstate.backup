        "machine_type": "n2-standard-8",
        "metadata": {
          "candidate_priority": "50",
          "environment": "nonprod",
          "formation": "default",
          "pg_cluster_id": "nonprod-ha-cluster-01",
          "pg_controller_cooldown": "600",
          "pg_failback_enabled": "true",
